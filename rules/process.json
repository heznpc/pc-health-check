[
  {
    "id": "miner_xmrig",
    "description": "XMRig (가장 흔한 악성 채굴기)",
    "when": { "name.iregex": "^xmrig.*$" },
    "then": {
      "risk": "danger",
      "note": "XMRig 계열 Monero 채굴기입니다. 악성코드일 가능성이 매우 높습니다.",
      "finding": {
        "category": "check_cpu",
        "title": "채굴/악성 프로세스 의심: {name}",
        "detail": "{note} 경로: {path}, PID {pid_}"
      }
    }
  },
  {
    "id": "miner_generic",
    "description": "알려진 채굴기 이름 패턴",
    "when": { "name.iregex": "^(minerd|cgminer|bfgminer|ethminer|phoenixminer|claymore|nanominer|lolminer|t-rex|gminer|nbminer|srbminer|teamredminer|wildrig|cpuminer|coinminer|xmr-stak).*$" },
    "then": {
      "risk": "danger",
      "note": "알려진 암호화폐 채굴기입니다.",
      "finding": {
        "category": "check_cpu",
        "title": "채굴/악성 프로세스 의심: {name}",
        "detail": "{note} 경로: {path}, PID {pid_}"
      }
    }
  },
  {
    "id": "rat_known",
    "description": "알려진 RAT(원격제어 트로이목마)",
    "when": { "name.iregex": "^(darkcomet|njrat|quasar|nanocore|remcos).*$" },
    "then": {
      "risk": "danger",
      "note": "알려진 원격제어 악성코드(RAT)입니다.",
      "finding": {
        "category": "check_cpu",
        "title": "원격제어 악성코드 의심: {name}",
        "detail": "{note} 경로: {path}, PID {pid_}"
      }
    }
  },
  {
    "id": "temp_high_cpu",
    "description": "임시 폴더 고CPU 실행 - 채굴기 흔적",
    "when": {
      "path.iregex": "(AppData\\\\Local\\\\Temp|\\\\Windows\\\\Temp\\\\|/tmp/|/var/tmp/)",
      "cpu.gte": 100
    },
    "then": {
      "risk": "danger",
      "note": "임시 폴더에서 CPU를 많이 쓰는 프로세스. 채굴기 가능성 높음.",
      "finding": {
        "category": "check_cpu",
        "title": "임시 폴더 고CPU 프로세스: {name}",
        "detail": "{note} 경로: {path}"
      }
    }
  },
  {
    "id": "temp_exec",
    "description": "임시 폴더 실행 - 일반 의심",
    "when": { "path.iregex": "(AppData\\\\Local\\\\Temp|\\\\Windows\\\\Temp\\\\|/tmp/|/var/tmp/)" },
    "then": {
      "risk": "warning",
      "note": "임시 폴더에서 실행 중 - 확인 필요"
    }
  },
  {
    "id": "windows_system",
    "description": "Windows 시스템 폴더",
    "when": { "path.iregex": "^C:\\\\Windows\\\\(System32|SysWOW64)\\\\" },
    "then": {
      "risk": "safe",
      "note": "Windows 시스템 폴더의 프로그램"
    }
  },
  {
    "id": "program_files",
    "description": "정상 설치 경로",
    "when": { "path.iregex": "^C:\\\\Program Files" },
    "then": {
      "risk": "info",
      "note": "Program Files에 정상 설치된 프로그램"
    }
  },
  {
    "id": "macos_system_path",
    "description": "macOS 시스템 경로",
    "when": { "path.iregex": "^(/System/|/usr/libexec/|/usr/sbin/|/usr/bin/)" },
    "then": { "risk": "safe", "note": "macOS 시스템 경로" }
  },
  {
    "id": "macos_applications",
    "description": "macOS /Applications",
    "when": { "path.iregex": "^/Applications/" },
    "then": { "risk": "info", "note": "정상 설치된 앱" }
  },
  {
    "id": "appdata_installed",
    "description": "사용자 폴더 설치",
    "when": { "path.iregex": "AppData\\\\Roaming|AppData\\\\Local" },
    "then": { "risk": "info", "note": "사용자 폴더에 설치된 프로그램" }
  },
  {
    "id": "vt_malicious_many",
    "description": "VT 3개 이상 악성 진단 = 위험",
    "when": { "vt.malicious.gte": 3 },
    "then": {
      "risk": "danger",
      "note": "VirusTotal에서 다수 백신이 악성으로 진단했습니다.",
      "finding": {
        "category": "check_cpu",
        "title": "VirusTotal 악성 판정: {name}",
        "detail": "{note} 해시: {vt.hash}"
      }
    }
  },
  {
    "id": "vt_malicious_one_two",
    "description": "VT 1-2개 악성 진단 = 주의 (오탐 가능)",
    "when": { "vt.malicious.gte": 1, "vt.malicious.lt": 3 },
    "then": {
      "risk": "warning",
      "note": "VirusTotal에서 소수 백신이 악성 진단 (오탐 가능성).",
      "finding": {
        "category": "check_cpu",
        "title": "VirusTotal 주의: {name}",
        "detail": "{note} 해시: {vt.hash}"
      }
    }
  },
  {
    "id": "sig_unsigned_system",
    "description": "Windows 시스템 폴더의 미서명 파일 = 위험",
    "when": {
      "path.iregex": "^C:\\\\Windows\\\\(System32|SysWOW64)\\\\",
      "sig.verified.equals": false
    },
    "then": {
      "risk": "danger",
      "note": "시스템 폴더에 서명 없는 파일 (악성코드 의심)",
      "finding": {
        "category": "check_cpu",
        "title": "서명 검증 실패: {name}",
        "detail": "{note} 경로: {path}"
      }
    }
  }
]
